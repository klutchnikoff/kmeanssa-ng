# Experiment outputs are regenerated by reproduce.py; keep only the folders.
results/*
figures/*
!results/.gitkeep
!figures/.gitkeep

# Heavy pairwise-distance cache of the frozen net; rebuilt on demand from data/.
cache/

# Only the 5000-node frozen net is committed; smaller ones are test artifacts.
data/sphere_net_*.npz
!data/sphere_net_5000.npz
